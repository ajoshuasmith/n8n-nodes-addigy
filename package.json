{
  "name": "n8n-nodes-addigy",
  "version": "1.0.0",
  "description": "n8n community node for Addigy API integration",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "addigy",
    "mdm",
    "apple",
    "device-management"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ajoshuasmith/n8n-nodes-addigy",
  "author": {
    "name": "Joshua Smith",
    "email": "ajoshuasmith@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajoshuasmith/n8n-nodes-addigy.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lint:fix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AddigyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Addigy/Addigy.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^5.0.0",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
